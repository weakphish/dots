.DS_Store

# Secrets and machine-local generated state that should never land in dotfiles.
**/.env
**/.env.*
**/*.pem
**/*.key
**/auth.json
**/credentials
**/Session.vim
**/fish_variables

config/dot-codex/auth.json
config/dot-codex/config.toml
config/dot-codex/models_cache.json
config/dot-codex/version.json
/.agent-shell/

# mise per-machine, non-committed config. MISE_ENV is set here on each box.
# (Also matched by config/dot-config/fish/conf.d/.gitignore, kept explicit.)
config/dot-config/fish/conf.d/local.fish
mise.local.toml
mise.*.local.toml

# Logs that leak into the nvim source dir.
**/nvim.log
