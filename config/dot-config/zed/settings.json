// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    // ── THEME & TYPOGRAPHY ──────────────────────────────────────────
    // Visual defaults for colors, editor text, and structural guides.
    "theme": {
        "mode": "dark",
        "light": "Gruvbox Light",
        "dark": "Gruvbox Dark",
    },
    "buffer_font_family": "JetBrains Mono",
    "buffer_font_size": 13.0,
    "colorize_brackets": true,
    "lsp_document_colors": "inlay",
    "indent_guides": {
        "line_width": 2,
        "active_line_width": 3,
        "coloring": "indent_aware",
    },

    // ── EDITING & NAVIGATION ────────────────────────────────────────
    // Core editing behavior, Vim emulation, and navigation aids.
    "vim_mode": true,
    "vim": {
        "toggle_relative_line_numbers": true,
        "use_system_clipboard": "on_yank",
    },
    "relative_line_numbers": "enabled",
    "tab_size": 4,
    "wrap_guides": [120],
    "sticky_scroll": {
        "enabled": true,
    },

    // ── CODE INTELLIGENCE & DIAGNOSTICS ─────────────────────────────
    // LSP-backed symbols, inline hints, signatures, and diagnostic display.
    "document_symbols": "on",
    "show_signature_help_after_edits": true,
    "auto_signature_help": false,
    "inlay_hints": {
        // Global switch to toggle hints on and off, switched off by default.
        "enabled": true,
        // Toggle certain types of hints on and off, all switched on by default.
        "show_type_hints": true,
        "show_parameter_hints": true,
        // Corresponds to null/None LSP hint type value.
        "show_other_hints": true,
    },
    "diagnostics": {
        // Whether to show warnings or not by default.
        "include_warnings": true,
        // Settings for inline diagnostics.
        "inline": {
            // Whether to show diagnostics inline or not.
            "enabled": true,
        },
    },

    // ── PANELS & WORKSPACE UI ───────────────────────────────────────
    // Dock placement and sizing for persistent panels and transient UI.
    "project_panel": {
        "dock": "left",
        "default_width": 350.0,
    },
    "git_panel": {
        "dock": "left",
        "tree_view": true,
        "status_style": "icon",
        "default_width": 400.0,
    },
    "outline_panel": {
        "dock": "right",
    },
    "collaboration_panel": {
        "button": false,
        "dock": "right",
    },
    "file_finder": {
        "modal_max_width": "medium",
    },
    "which_key": {
        "enabled": true,
    },
    "resize_all_panels_in_dock": [],

    // ── GIT ─────────────────────────────────────────────────────────
    // Version-control display behavior inside buffers and panels.
    "git": {
        "inline_blame": {
            "show_commit_summary": true,
        },
    },

    // ── TERMINAL ────────────────────────────────────────────────────
    // Integrated terminal font, shell, and virtual environment activation.
    "terminal": {
        "font_family": "JetBrainsMono Nerd Font",
        "shell": "system",
        "detect_venv": {
            "on": {
                "activate_script": "default",
            },
        },
    },

    // ── AI & ASSISTANT ──────────────────────────────────────────────
    // Agent integrations, assistant models, and inline edit predictions.
    "agent_servers": {
        "opencode": {
            "type": "registry",
        },
        "github-copilot": {
            "type": "registry",
        },
    },
    "agent": {
        "sidebar_side": "right",
        "dock": "right",
        "default_profile": "ask",
        "default_model": {
            "provider": "copilot_chat",
            "model": "gpt-5.5",
        },
    },
    "show_edit_predictions": false,

    // ── FILE TYPES & LANGUAGES ──────────────────────────────────────
    // File association overrides and per-language formatter behavior.
    "file_types": {
        "Dockerfile": ["Dockerfile*"],
        "YAML": ["*yaml.gotmpl"],
    },
    "languages": {
        "YAML": {
            "format_on_save": "off",
            "tab_size": 2,
        },
        "Python": {
            "language_servers": ["ty", "!basedpyright", "ruff"],
            "format_on_save": "on",
            "formatter": [
                {
                    "external": {
                        "command": "black",
                        "arguments": ["-"],
                    },
                },
                {
                    "external": {
                        "command": "isort",
                        "arguments": ["-"],
                    },
                },
            ],
        },
        "JavaScript": {
            "formatter": "prettier",
        },
        "TypeScript": {
            "formatter": "prettier",
        },
    },

    // ── LANGUAGE SERVERS ────────────────────────────────────────────
    // Server-specific LSP settings that tune diagnostics and formatting.
    "lsp": {
        "basedpyright": {
            "settings": {
                "basedpyright.analysis": {
                    "diagnosticMode": "workspace",
                    "typeCheckingMode": "standard",
                },
                "python": {
                    "pythonPath": ".venv/bin/python",
                },
            },
        },
        "ty": {
            "settings": {
                "diagnosticMode": "workspace",
            },
        },
        "ruff": {
            "initialization_options": {
                "settings": {
                    // Ruff server settings goes here.
                    "lineLength": 120,
                    "lint": {
                        "ignore": ["I"], // using isort with specific rules for now
                    },
                },
            },
        },
    },
}
