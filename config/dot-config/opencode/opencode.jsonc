{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "agent": {
    "ask": {
      "mode": "primary",
      "prompt": "{file:./prompts/ask.prompt.md}",
      "permission": {
        "edit": "deny",
        "bash": "allow",
      },
    },
    "wiki-doc-writer": {
      "description": "Use to write, draft, or revise documentation pages for a team wiki or repository documentation. This includes creating new guides, documenting processes, explaining technical concepts, or restructuring existing documentation content.",
      "mode": "subagent",
      "prompt": "{file:./prompts/wiki-doc-writer.prompt.md}",
    },
    "code-simplifier": {
      "description": "Use to simplify a given set of code as scoped by the user without changing functionality.",
      "mode": "subagent",
      "prompt": "{file:./prompts/code-simplifier.prompt.md}",
    },
    "debug": {
      "mode": "primary",
      "prompt": "{file:./prompts/systematic-debugging.prompt.md}",
      "permission": {
        "edit": "deny",
        "bash": "allow",
      },
    },
  },
}
